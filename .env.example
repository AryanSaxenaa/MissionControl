# HydraDB API — required for @hydradb/sdk and @hydradb/mcp
HYDRA_DB_API_KEY=hdb-your-api-key
HYDRA_DB_TENANT_ID=your-tenant-id
HYDRA_DB_SUB_TENANT_ID=your-project-name

# HydraDB CLI — separate env var name for tenant
HYDRADB_TENANT_ID=your-tenant-id
HYDRADB_OUTPUT=human

# MissionControl SDK
HYDRA_API_KEY=hdb-your-api-key
HYDRA_TENANT_ID=your-tenant-id

# LLM for semantic/architectural conflict detection (optional)
# Uses openrouter/owl-alpha — no Anthropic dependency
OPENROUTER_API_KEY=sk-or-your-key

# Anthropic (legacy — no longer used, kept for reference only)
# ANTHROPIC_API_KEY=sk-ant-your-key
